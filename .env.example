# =============================
# AI-ready data pipeline (.env sample)
# Copy this file to .env and set real values.
# =============================

# Pipeline target directory (required)
PROJECT_DIR=project_test

# ---------- Azure OpenAI (required) ----------
# Example: https://<your-aoai-resource>.openai.azure.com/openai/v1/
AZURE_OPENAI_API_ENDPOINT=

# Main model/deployment for text processing (summary, extraction)
AZURE_OPENAI_MODEL=gpt-5.4

# Embedding model/deployment for vector generation
AZURE_OPENAI_EMBED_MODEL=text-embedding-3-large

# Small/cheap model for filter extraction
FILTER_MODEL_DEPLOYMENT=gpt-5.4-nano

# ---------- Azure Content Understanding (required for 010) ----------
# Example: https://<your-cu-resource>.services.ai.azure.com/
AZURE_CONTENT_UNDERSTANDING_ENDPOINT=

# ---------- Azure AI Search (required for 050) ----------
# Example: https://<your-search-service>.search.windows.net
AI_SEARCH_ENDPOINT=

# Target index name to create/upload
AI_SEARCH_INDEX_NAME=index_test

# Optional settings
AI_SEARCH_SEMANTIC=semanticConfig
AI_SEARCH_API_VERSION=2024-07-01

# ----------------------------------------------
# Optional (only if you run _common/figure_vision.py directly)
# FDPO_AZURE_OPENAI_API_ENDPOINT=
# FDPO_AZURE_OPENAI_API_KEY=
# ----------------------------------------------
